# Point the frontend chatbot at your local Hermes subscription proxy.
# 1. Install Hermes (see https://hermes-agent.nousresearch.com)
# 2. Authenticate your xAI/Grok subscription:
#    hermes proxy providers   # or hermes model / hermes auth add xai-oauth
# 3. Start the proxy:
#    hermes proxy start --provider xai
#    (or --provider xai-oauth for SuperGrok / X Premium+ browser login)
#
# Default: http://localhost:8645/v1
# Set this if you use different host/port.
VITE_HERMES_URL=http://localhost:8645/v1
